generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
}

model AppUser {
  id           String          @id @default(cuid())
  username     String          @unique
  displayName  String
  passwordHash String
  role         UserRole        @default(USER)
  isActive     Boolean         @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  sessions     AppSession[]
  adminLogs    AdminAuditLog[]
  orderLogs    OrderLog[]
  financeLogs  FinanceLog[]
  userSettings UserSettings?
}

model AppSession {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  ipAddress String?
  userAgent String?
  user      AppUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String
  action      String
  targetUserId String?
  metadata    Json?
  createdAt   DateTime @default(now())
  adminUser   AppUser  @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, createdAt])
}

model OrderLog {
  id            String    @id @default(cuid())
  userId        String
  clientKey     String
  timestamp     BigInt
  formattedDate String
  serviceType   String
  latitude      Float?
  longitude     Float?
  weatherStatus String?
  grossFare     Decimal?  @db.Decimal(12, 2)
  commissionCut Decimal?  @db.Decimal(12, 2)
  netFare       Decimal?  @db.Decimal(12, 2)
  createdAt     DateTime  @default(now())
  user          AppUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clientKey])
  @@index([userId, timestamp])
  @@index([userId, formattedDate])
}

model FinanceLog {
  id            String   @id @default(cuid())
  userId        String
  clientKey     String
  timestamp     BigInt
  formattedDate String
  entryType     String
  category      String
  amount        Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now())
  user          AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clientKey])
  @@index([userId, timestamp])
  @@index([userId, formattedDate])
}

model UserSettings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  commissionRate        Int      @default(10)
  currentVirtualBalance Decimal  @default(0) @db.Decimal(12, 2)
  dailyTarget           Decimal  @default(100000) @db.Decimal(12, 2)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
}
