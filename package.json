    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed:admin": "tsx scripts/seed-admin.ts",
    "verify": "npm run db:generate && npm run lint && npm run build"
  },
  "dependencies": {
