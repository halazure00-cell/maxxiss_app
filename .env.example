PORT=3000

# Runtime database URL untuk Vercel/serverless.
# Isi dengan pooled Supabase Postgres URL.
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct database URL untuk migration/generate Prisma.
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres"

# Opsional. Jika kosong, advice AI tetap jalan memakai fallback rule-based.
GEMINI_API_KEY=""

# Bootstrap admin pertama.
ADMIN_BOOTSTRAP_USERNAME="developer"
ADMIN_BOOTSTRAP_PASSWORD="ganti-password-ini"
ADMIN_BOOTSTRAP_DISPLAY_NAME="Developer Maxxiss"

# Timezone bisnis untuk grouping "hari" data order/finance.
BUSINESS_TIMEZONE="Asia/Jakarta"

# Rate limiting terdistribusi (rekomendasi untuk Vercel production).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Default true. Jika redis down, request sensitif akan ditolak sementara.
RATE_LIMIT_FAIL_CLOSED="true"
