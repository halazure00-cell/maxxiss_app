PORT=3000

# Prisma SQLite lokal.
# Gunakan nilai ini agar database tetap tersimpan di prisma/dev.db.
DATABASE_URL="file:./dev.db"

# Opsional. Jika diisi, server lokal akan memakai Gemini untuk saran generatif.
# Jika kosong, aplikasi tetap berjalan dan otomatis memakai fallback rule-based.
GEMINI_API_KEY=""
